<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.HomeFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:background="@color/white">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/apptitleLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginStart="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/outerCard"
                tools:ignore="UseCompoundDrawables">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="33dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/app_name"
                    android:src="@mipmap/ic_launcher"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/appTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center_vertical"
                    android:letterSpacing=".2"
                    android:text="VidSave"
                    android:layout_marginStart="10dp"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/imageView"
                    app:layout_constraintTop_toTopOf="parent" />


                <!--            <ImageView-->
                <!--                android:id="@+id/modifyFoldersBtn"-->
                <!--                android:layout_width="25dp"-->
                <!--                android:layout_height="25dp"-->
                <!--                android:layout_marginEnd="10dp"-->
                <!--                android:foregroundGravity="right"-->
                <!--                android:src="@drawable/folder"-->
                <!--                app:layout_constraintBottom_toBottomOf="parent"-->
                <!--                app:layout_constraintEnd_toEndOf="parent"-->
                <!--                app:layout_constraintTop_toTopOf="parent" />-->



            </androidx.constraintlayout.widget.ConstraintLayout>


            <com.google.android.material.card.MaterialCardView
                android:layout_marginTop="15dp"
                android:id="@+id/outerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:strokeColor="@color/transparent"
                app:strokeWidth="0dp"
                app:cardCornerRadius="35dp"
                app:cardBackgroundColor="@color/backgroundColor"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/apptitleLayout">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_marginBottom="20dp"
                    android:layout_height="wrap_content">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/cardColor"
                        app:cardCornerRadius="35dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeColor="@color/transparent"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="10dp"
                            android:orientation="vertical"
                            android:padding="10dp">


                            <ImageView
                                android:id="@+id/logo"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:background="@color/cardColor"
                                android:src="@drawable/evd_logo"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/titleText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_bold"
                                android:gravity="center"
                                android:text="VidSave - Video Downloader"
                                android:textColor="@color/black"
                                android:textSize="22sp"
                                app:layout_constraintBottom_toTopOf="@id/titleDesc"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/logo" />

                            <TextView
                                android:id="@+id/titleDesc"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_medium"
                                android:gravity="center"
                                android:text="Do Not Look Below! Explore VidSave, A Free Solution To Quickly Download Videos With Just One Click"
                                android:textColor="@color/backgroundColor"
                                android:textSize="12sp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/titleText" />


                            <EditText
                                android:id="@+id/urlInput"
                                style="@style/textStyle"
                                android:background="@drawable/edittext_bg"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:layout_marginBottom="30dp"
                                android:drawableStart="@drawable/link"
                                android:hint="@string/paste_video_url_here_hint"
                                android:inputType="textNoSuggestions"
                                android:padding="18dp"
                                android:paddingEnd="50dp"
                                android:focusable="true"
                                android:cursorVisible="true"
                                android:ellipsize="end"
                                android:singleLine="true"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/titleDesc"
                                tools:ignore="RtlSymmetry" />

                            <ImageView
                                android:id="@+id/pasteLink"
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:layout_marginEnd="15dp"
                                android:src="@drawable/copy"
                                app:layout_constraintBottom_toBottomOf="@+id/urlInput"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@+id/urlInput" />


                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <Button
                        android:id="@+id/downloadBtn"
                        android:layout_width="wrap_content"
                        android:minWidth="200dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="-25dp"
                        android:backgroundTint="@color/primaryRed"
                        android:fontFamily="@font/poppins_bold"
                        android:padding="10dp"
                        android:hapticFeedbackEnabled="true"
                        android:text="@string/download_btn_txt"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="@+id/cardView"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />


                    <ProgressBar
                        android:id="@+id/downloadProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:max="100"
                        android:progress="90"
                        android:indeterminateTint="@color/primaryRed"
                        android:progressDrawable="@drawable/progress_bar_download"
                        android:visibility="gone"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="10dp"
                        app:layout_constraintTop_toBottomOf="@id/downloadBtn"

                   />


                    <TextView
                        android:id="@+id/progressText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="0% Downloaded"
                        android:textColor="#838383"
                        android:fontFamily="@font/poppins_bold"
                        android:visibility="gone"
                        android:gravity="center"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/downloadProgress" />



                    <TextView
                        android:id="@+id/textView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_medium"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="10dp"
                        android:text="Completely free with no hidden charges or subscriptions"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:textDirection="ltr"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/progressText"
                      />


                    <TextView
                        android:id="@+id/textView2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="10dp"
                        android:text="Download videos in Full HD, 4K and original quality"
                        android:textColor="#666666"
                        android:textDirection="ltr"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/textView" />

                    <TextView
                        android:id="@+id/textView4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="10dp"
                        android:text="Lightning fast video downloads with optimized speed."
                        android:textColor="#666666"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@+id/textView2" />


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="10dp"
                        android:layout_marginBottom="20dp"
                        android:text="Do your work after hitting the download button and we will send you a notification letting you know when your download has finised."
                        android:textColor="#666666"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@+id/textView4" />



                </androidx.constraintlayout.widget.ConstraintLayout>






            </com.google.android.material.card.MaterialCardView>


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.core.widget.NestedScrollView>


</FrameLayout>