<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_variant"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/bg_input_modern"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_medium"
            android:maxLines="1"
            android:text="@string/browser_url_hint"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:padding="3dp"
            android:src="@drawable/copy"
            app:tint="@color/primaryRed" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:padding="3dp"
            android:src="@drawable/link"
            app:tint="@color/primaryRed" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@color/divider" />

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.Material3.Button.ElevatedButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:enabled="false"
        android:fontFamily="@font/poppins_bold"
        android:text="@string/browser_download_fab"
        android:textAllCaps="false"
        android:textSize="12sp"
        app:backgroundTint="@color/primaryRed"
        app:icon="@drawable/evd_logo"
        app:iconSize="16dp"
        app:iconTint="@android:color/white" />
</LinearLayout>
