    <!-- How-to guide -->
    <string name="how_to_title">How to use VidSave</string>
    <string name="how_to_intro_title">Save any video in 4 steps</string>
    <string name="how_to_intro_desc">Follow the guide below — each step shows what you\'ll see in the app.</string>
    <string name="how_to_step1_title">Copy &amp; paste the link</string>
    <string name="how_to_step1_desc">Copy the video URL from TikTok, Instagram, YouTube, Facebook, or any site. On Home, tap the paste icon or long-press the input field.</string>
    <string name="how_to_step2_title">Preview &amp; download</string>
    <string name="how_to_step2_desc">Wait for the preview thumbnail to load, then tap Download Video. Progress appears on screen and in your notification bar.</string>
    <string name="how_to_step3_title">Use the browser when needed</string>
    <string name="how_to_step3_desc">If download fails or the site asks you to sign in, tap Browser. Paste the link in the address bar (not Google search), tap Go, wait for the page to load, then tap Download and choose \"This page\".</string>
    <string name="how_to_step4_title">Find videos in Library</string>
    <string name="how_to_step4_desc">Open the Library tab to play, share, or manage everything you\'ve saved. Pull down to refresh the list.</string>
    <string name="how_to_tips_title">Quick tips</string>
    <string name="how_to_tips_body">• Always paste the full video page URL, not a search result.\n• On TikTok, choose \"This page\" instead of a direct file link.\n• Wait for the page to finish loading before tapping Download in the browser.\n• Check Settings for your download folder path and app updates.</string>
